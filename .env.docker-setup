# Configuration du setup Docker pour ce projet.
# Ce fichier DOIT être versionné (gitté) pour standardiser l'environnement de tous les développeurs.

# Le préfixe unique pour tous les conteneurs, volumes, et réseaux Docker.
DOCKER_PROJECT_PREFIX=chess

# Le préfixe pour les ports mappés sur l'hôte, pour éviter les conflits.
# (ex: 32 -> 3280, 3279, 3232)
DOCKER_PORT_PREFIX=48